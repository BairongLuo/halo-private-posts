{
  "name": "halo-private-posts-ui",
  "private": true,
  "version": "0.8.17",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "run-p build:console build:reader",
    "build:console": "vite build",
    "build:reader": "vite build --config reader.vite.config.ts",
    "dev": "vite build --watch --mode=development",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test --grep-invert @destructive",
    "test:e2e:uninstall": "playwright test --grep @destructive",
    "test:unit": "vitest --config vitest.config.ts --run",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@halo-dev/api-client": "2.24.0",
    "@halo-dev/components": "2.24.0",
    "@halo-dev/richtext-editor": "2.24.0",
    "@halo-dev/ui-shared": "2.24.0",
    "axios": "^1.12.2",
    "marked": "15.0.12",
    "scrypt-js": "3.0.1",
    "vue": "3.5.17"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "2.24.0",
    "@playwright/test": "1.56.1",
    "@rsbuild/core": "1.2.0",
    "@rsbuild/plugin-vue": "1.2.0",
    "@tsconfig/node20": "20.1.6",
    "@types/node": "20.19.1",
    "@vitejs/plugin-vue": "6.0.6",
    "@vue/tsconfig": "0.7.0",
    "jsdom": "26.1.0",
    "npm-run-all2": "7.0.2",
    "typescript": "5.8.3",
    "vite": "^8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "2.2.10"
  },
  "packageManager": "npm@10.8.2"
}

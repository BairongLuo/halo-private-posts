    "test:unit": "vitest --run --environment node",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@halo-dev/api-client": "2.24.0",
    "@halo-dev/components": "2.24.0",
    "@halo-dev/richtext-editor": "2.24.0",
    "@halo-dev/ui-shared": "2.24.0",
    "axios": "^1.12.2",
    "marked": "15.0.12",
    "scrypt-js": "3.0.1",
    "vue": "3.5.17"
  },
  "devDependencies": {
    "@rsbuild/core": "1.2.0",
    "@rsbuild/plugin-vue": "1.2.0",
    "@halo-dev/ui-plugin-bundler-kit": "2.24.0",
    "@tsconfig/node20": "20.1.6",
    "@types/node": "20.19.1",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/tsconfig": "0.7.0",
    "jsdom": "26.1.0",
    "npm-run-all2": "7.0.2",
    "typescript": "5.8.3",
    "vite": "5.3.2",
    "vitest": "3.2.4",
    "vue-tsc": "2.2.10"

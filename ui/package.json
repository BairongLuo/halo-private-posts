{
  "name": "halo-private-posts-ui",
  "private": true,
  "version": "0.5.5",
  "type": "module",
  "scripts": {
    "build": "run-p build:console build:reader",
    "build:console": "vite build",
    "build:reader": "vite build --config reader.vite.config.ts",
